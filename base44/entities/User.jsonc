{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "parent",
        "youth",
        "kinship_caregiver",
        "foster_parent",
        "peer_mentor",
        "behavioral_health_worker",
        "casa_gal",
        "school_staff",
        "attorney",
        "admin",
        "founder",
        "user"
      ],
      "default": "parent"
    },
    "onboarding_completed": {
      "type": "boolean",
      "default": false
    },
    "preferred_language": {
      "type": "string",
      "enum": [
        "en",
        "es",
        "so"
      ],
      "default": "en"
    },
    "county": {
      "type": "string"
    },
    "zip_code": {
      "type": "string"
    },
    "housing_resources_zip": {
      "type": "string"
    },
    "survivor_mode_enabled": {
      "type": "boolean",
      "default": false
    },
    "quick_exit_url": {
      "type": "string",
      "default": "https://weather.com"
    },
    "vault_pin_enabled": {
      "type": "boolean",
      "default": false
    },
    "sensitive_action_reauth_at": {
      "type": "string",
      "format": "date-time"
    },
    "account_status": {
      "type": "string",
      "enum": [
        "active",
        "locked",
        "pending_review",
        "deletion_requested"
      ],
      "default": "active"
    }
  }
}