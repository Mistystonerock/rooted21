{
  "name": "AdminPermissions",
  "type": "object",
  "properties": {
    "admin_email": {
      "type": "string",
      "description": "Email of the admin user"
    },
    "admin_name": {
      "type": "string",
      "description": "Name of the admin user"
    },
    "permissions": {
      "type": "array",
      "description": "Permissions granted to this admin",
      "items": {
        "type": "string",
        "enum": [
          "manage_local_resources",
          "update_verified_services",
          "moderate_community",
          "assist_users",
          "manage_assigned_county_resources",
          "view_admin_dashboard"
        ]
      },
      "default": []
    },
    "assigned_counties": {
      "type": "array",
      "description": "Ohio counties this admin may manage",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "organization_id": {
      "type": "string",
      "description": "Organization this admin may manage"
    },
    "organization_name": {
      "type": "string"
    },
    "created_by": {
      "type": "string",
      "description": "Founder who granted this access"
    },
    "notes": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "admin_email",
    "admin_name",
    "created_by"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "founder"
      }
    },
    "read": {
      "$or": [
        {
          "admin_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "founder"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "founder"
      }
    },
    "delete": false
  }
}