{
  "name": "CourtFiling",
  "type": "object",
  "properties": {
    "owner_email": {
      "type": "string",
      "description": "User who created this filing"
    },
    "case_id": {
      "type": "string",
      "description": "Linked case file ID"
    },
    "case_plan_id": {
      "type": "string",
      "description": "Linked CasePlanChecklist ID"
    },
    "filing_type": {
      "type": "string",
      "enum": [
        "service_request",
        "status_report",
        "status_update",
        "compliance_summary",
        "hearing_statement",
        "communication_exhibit"
      ],
      "default": "service_request",
      "description": "Type of court-ready filing"
    },
    "title": {
      "type": "string",
      "description": "Filing title"
    },
    "child_name": {
      "type": "string",
      "description": "Child or case subject"
    },
    "family_case_name": {
      "type": "string",
      "description": "Family or case name used in the caption"
    },
    "court_name": {
      "type": "string",
      "description": "Court or agency name used in the caption"
    },
    "draft_markdown": {
      "type": "string",
      "description": "Generated court-ready filing draft text"
    },
    "preparation_tasks": {
      "type": "array",
      "description": "Specific tasks to complete before submitting",
      "items": {
        "type": "string"
      }
    },
    "source_summary": {
      "type": "string",
      "description": "Summary of case plan and communication audit data used"
    },
    "include_declaration": {
      "type": "boolean",
      "default": false,
      "description": "Whether the user chose to include a formal perjury declaration and signature block"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready_for_review",
        "final_signed"
      ],
      "default": "draft",
      "description": "Draft = still has missing info; Ready for Review = complete and reviewed; Final/Signed = signed and saved"
    },
    "signed_file_url": {
      "type": "string",
      "description": "URL of signed official document file"
    },
    "signed_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the user signed the filing"
    },
    "signature_name": {
      "type": "string",
      "description": "Printed signer name"
    }
  },
  "required": [
    "owner_email",
    "filing_type",
    "title"
  ],
  "rls": {
    "create": {
      "data.owner_email": "{{user.email}}"
    },
    "read": {
      "data.owner_email": "{{user.email}}"
    },
    "update": {
      "data.owner_email": "{{user.email}}"
    },
    "delete": {
      "data.owner_email": "{{user.email}}"
    }
  }
}